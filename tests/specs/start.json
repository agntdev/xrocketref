[
  {
    "name": "/start replies with the welcome + main menu",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          {
            "method": "sendMessage",
            "payload": { "text": "👋 Welcome! Tap a button below to get started." }
          }
        ]
      }
    ]
  },
  {
    "name": "Back to main menu from /start",
    "steps": [
      {
        "send": { "text": "/start" },
        "expect": [
          { "method": "sendMessage" }
        ]
      },
      {
        "send": { "callback": "menu:main" },
        "expect": [
          { "method": "editMessageText", "payload": { "text": "👋 Welcome! Tap a button below to get started." } }
        ]
      }
    ]
  }
]
